PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=verify-full
HF_TOKEN=
MISTRAL_MODEL=Qwen/Qwen2.5-7B-Instruct
FLAN_MODEL=Qwen/Qwen2.5-7B-Instruct
